{
  "expo": {
    "name": "CarGo",
    "slug": "cargo-rental",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/cargo2.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#DC3C3C"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.cargo.rental"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0F"
      },
      "package": "com.cargo.rental",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "sdkVersion": "54.0.0",
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        { "cameraPermission": "Allow CarGo to access your camera." }
      ],
      [
        "expo-image-picker",
        { "photosPermission": "Allow CarGo to access your photos." }
      ]
    ],
    "scheme": "cargo"
  }
}
